# Per-Dockerfile ignore file for e2e/Dockerfile (BuildKit picks this up automatically).
#
# IMPORTANT: the build context is the repo root (`context: ./` in docker-compose.yml),
# because e2e/Dockerfile copies from both `e2e/` and its sibling `unit_tests/`.
# Therefore every pattern below is relative to the repo root, NOT to e2e/ — hence the
# `e2e/` / `unit_tests/` prefixes. A plain `e2e/.dockerignore` is never read for this build.

e2e/.env.test

# ------- e2e/.gitignore -------

e2e/npm-debug.log*
e2e/yarn-debug.log*
e2e/yarn-error.log*
e2e/node_modules/
e2e/test-results/
e2e/playwright-report/
e2e/playwright/.cache/

e2e/tests/actual/*
e2e/tests/diffs/*

!e2e/tests/actual/01NYU_AD-AD/
e2e/tests/actual/01NYU_AD-AD/*
!e2e/tests/actual/01NYU_AD-AD/.gitkeep
!e2e/tests/actual/01NYU_AD-AD_DEV/
e2e/tests/actual/01NYU_AD-AD_DEV/*
!e2e/tests/actual/01NYU_AD-AD_DEV/.gitkeep

!e2e/tests/diffs/01NYU_AD-AD/
e2e/tests/diffs/01NYU_AD-AD/*
!e2e/tests/diffs/01NYU_AD-AD/.gitkeep
!e2e/tests/diffs/01NYU_AD-AD_DEV/
e2e/tests/diffs/01NYU_AD-AD_DEV/*
!e2e/tests/diffs/01NYU_AD-AD_DEV/.gitkeep

